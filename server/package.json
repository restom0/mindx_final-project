{
  "name": "mindx-todo-server",
  "version": "2.0.0",
  "private": true,
  "description": "Express Todo API with Prisma, PostgreSQL, Redis cache, i18n, and Swagger.",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon index.js",
    "start": "node index.js",
    "build": "prisma generate",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "node prisma/seed.js",
    "check": "node --check index.js && node --check src/server.js && node --check src/app.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.js\" \"prisma/**/*.js\" \"*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"prisma/**/*.js\" \"*.js\""
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.3.0",
    "ioredis": "^5.11.1",
    "morgan": "^1.11.0",
    "pg": "^8.22.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.5",
    "prisma": "^7.8.0"
  },
  "overrides": {
    "@hono/node-server": "^2.0.1"
  }
}
